# ============================================================
# init-cluster.env.example
# Copy to init-cluster.<tenant>.env and fill in values
# ============================================================

# --- Tenant ---
TENANT_NAME="im-u.com"
TENANT_DOMAIN="im-u.com"
OVERLAY_PATH="k8s/overlays/im-u.com"

# --- Server ---
SERVER_HOST="ubuntu-k8s-node-mac"
SERVER_USER="sebas"
SSH_KEY_PATH="$HOME/.ssh/id_ed25519"
KUBECONFIG_PATH="$HOME/.kube/im-u.com.yaml"

# --- Git ---
GIT_REPO_SSH="git@github.com:aitizate/forjate.git"
GIT_BRANCH="feat/overlay/im-u.com"  # or main once merged

# --- Cloudflare ---
CF_DNS_TOKEN=""         # Zone:DNS:Edit
CF_TUNNEL_TOKEN=""      # Account:Cloudflare Tunnel:Edit
CF_TUNNEL_ID=""         # "t" field from decoded tunnel token (base64)
CF_ACCOUNT_ID=""        # "a" field from decoded tunnel token (base64)
CF_LETSENCRYPT_EMAIL="setchevest@gmail.com"

# --- Google OAuth ---
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Cloudflare Tunnel (token del tunnel, NO el API token) ---
# Copiar desde Zero Trust → Networks → Connectors → [tunnel] → dashboard
# ⚠️ No copiar desde el comando brew/apt — puede truncarse
CF_TUNNEL_TOKEN_VALUE=""

# --- ArgoCD ---
ARGOCD_SSH_KEY_PATH="/tmp/argocd-deploy-key-${TENANT_NAME}"
